# Copy to .env.local for local development.
# For EAS production builds, define the same EXPO_PUBLIC_* names as encrypted secrets
# in the Expo dashboard (Project → Secrets) or via: eas env:create --name EXPO_PUBLIC_GEMINI_API_KEY --value ...

EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_TTS_API_KEY=
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# Optional — full App Store / Play URLs for share badges & onboarding taps.
# If unset, badges use STORE_WEB_LANDING_URL from src/constants/config.ts
EXPO_PUBLIC_APP_STORE_URL=
EXPO_PUBLIC_PLAY_STORE_URL=
