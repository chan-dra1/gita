# ─── CLIENT (mobile + web bundle) ────────────────────────────────
# These are PUBLIC by design. Anything set here is bundled into the app
# binary and can be extracted by anyone. Never put a real server secret
# (Gemini, Claude, Google TTS, Firebase admin) here.
#
# Copy to `.env.local` for local dev.
# For EAS production builds, set the same EXPO_PUBLIC_* names as encrypted
# secrets in Expo (Project → Secrets) or via:
#     eas env:create --name EXPO_PUBLIC_FIREBASE_API_KEY --value ...

# Where the mobile app calls our serverless API. On web in prod leave blank
# so the app uses the same origin.
EXPO_PUBLIC_API_BASE_URL=https://gita-rouge-tau.vercel.app

# Firebase web config — these are public by design (Firebase security is via
# Auth + Firestore rules, not by hiding these values).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# RevenueCat public SDK keys. Required for purchases on device.
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
# RevenueCat public SDK key for iOS (Apple).
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=

# Optional — full App Store / Play URLs for share badges & onboarding taps.
# If unset, badges use STORE_WEB_LANDING_URL from src/constants/config.ts.
EXPO_PUBLIC_APP_STORE_URL=
EXPO_PUBLIC_PLAY_STORE_URL=

# Optional — ElevenLabs voice id (not secret; the API key itself is server-side).
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=

# ── DO NOT ADD SERVER SECRETS HERE ──
# Gemini / Claude / Google TTS / Firebase admin keys belong in Vercel env
# vars. See `.env.server.example`.
