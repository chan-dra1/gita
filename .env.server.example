# ─── SERVER (Vercel serverless /api/*) ─────────────────────────────
# Copy these variable names into Vercel → Project → Settings → Environment
# Variables. They are read by `api/_lib/env.ts` at cold start; the function
# WILL REFUSE TO START if any required value is missing.
#
# Do NOT commit actual values.
# Do NOT prefix any of these with EXPO_PUBLIC_. Doing so would bundle them
# into the mobile + web client, which is exactly what we are preventing.

# ── Required ──
GEMINI_API_KEY=
CLAUDE_API_KEY=
TTS_API_KEY=

# Firebase Admin (for verifying client ID tokens server-side).
# Get from Firebase Console → Project Settings → Service Accounts → Generate
# new private key. Copy the three fields below from the JSON.
FIREBASE_PROJECT_ID=gita-app-390d7
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: paste the ENTIRE key including BEGIN/END lines. Vercel preserves
# \n in this value; our env loader converts them back to real newlines.
FIREBASE_PRIVATE_KEY=

# ── Optional ──

# Upstash Redis for distributed rate limiting across serverless regions.
# Without these, rate limiting falls back to per-instance in-memory (still
# works, just less strict). Recommended for prod.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Log level: debug | info | warn | error. Default: info.
LOG_LEVEL=info
