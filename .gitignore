# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Never commit a local Node binary tree or npm cache (Cursor/Git will crawl millions of lines)
node-arm64/
/node/
.npm-cache/
.expo_home/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# Playwright
test-results/
playwright-report/

# Local Gradle logs
gradle-apk-build.log

# Local Gradle user home (see scripts/android-release-apk.sh)
.gradle-user-home/

app-example

# generated native folders
/ios
/android
.vercel

# Project Cleanup (Performance)
/dist/
/node/
/node-arm64/
/.npm-cache/
buildlogs*.json
*.log

# Firebase Service Account Keys (SENSITIVE — never commit)
firebase-service-account.json
gita-app-*.json

