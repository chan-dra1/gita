<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="expo.modules.dharmablocker" >

    <uses-sdk android:minSdkVersion="24" />

    <!-- Permissions required for Dharma Mode -->
    <uses-permission
        xmlns:tools="http://schemas.android.com/tools"
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application>

        <!-- Foreground Service Declaration -->
        <service
            android:name="expo.modules.dharmablocker.DharmaForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse" >
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_SERVICE_TYPE"
                android:value="Monitoring distracting apps for spiritual focus/productivity." />
        </service>
    </application>

</manifest>